# Node environment
NODE_ENV=production
PORT=8080

# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_USER=paper_user
DB_PASSWORD=paperpass123
DB_NAME=paper_trading

# MySQL root password (for docker-compose)
MYSQL_ROOT_PASSWORD=rootpassword

# Redis Configuration
REDIS_URL=redis://redis:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1d

# Client Configuration
CLIENT_ORIGIN=http://localhost:5173

# Admin and Trader Credentials (change in production!)
ADMIN_EMAIL=admin@papertrading.local
ADMIN_PASSWORD=Admin123!
TRADER_PASSWORD=Trader123!

# Optional: Enable crypto polling service
ENABLE_CRYPTO_POLLING=false

# API Keys (if using external services)
ALPHA_VANTAGE_API_KEY=
DHANHQ_API_KEY=

# Ports for local development mapping
MYSQL_PORT=3306
REDIS_PORT=6379
